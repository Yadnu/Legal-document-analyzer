# ── Backend ──────────────────────────────────────────────────────────────────

# Postgres (matches docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://legaluser:legalpass@localhost:5432/legaldb
TEST_DATABASE_URL=postgresql+asyncpg://legaluser:legalpass@localhost:5432/legaldb_test

# CORS (JSON array of allowed frontend origins)
CORS_ORIGINS=["http://localhost:3000"]

# AWS / LocalStack
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=legal-documents

# Clerk — fill in from https://dashboard.clerk.com
CLERK_SECRET_KEY=
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
# Optional: set to enforce the JWT `iss` claim (e.g. https://<your-clerk-domain>)
CLERK_ISSUER=

# ── Frontend ─────────────────────────────────────────────────────────────────

# Exposed to the browser (must start with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
